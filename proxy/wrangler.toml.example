name = "forandringsteori-proxy"
main = "./worker.mjs"
compatibility_date = "2026-03-18"

[vars]
ALLOWED_ORIGIN = "https://<YOUR-USER>.github.io"
GEMINI_MODEL = "gemini-2.5-flash"
RATE_LIMIT_MAX_REQUESTS = "5"
RATE_LIMIT_WINDOW_MS = "60000"
MAX_FILE_SIZE_BYTES = "8388608"
MAX_TOTAL_SIZE_BYTES = "20971520"
